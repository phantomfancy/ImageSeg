@implements IDisposable
@inject SpaNavigationState Navigation

<div class="brand-block">
    <p class="brand-block__eyebrow">识别工作台</p>
    <button type="button" class="brand-block__title brand-block__title--button" @onclick="@(() => NavigateTo(AppView.Overview))">4C-ai装备识别工具</button>
    <p class="brand-block__summary">
        导入图片、视频或摄像头画面，完成装备检测、结果查看与导出。
    </p>
</div>

<input type="checkbox" title="切换导航菜单" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler')?.click()">
    <nav class="nav-sections">
        <button type="button" class="@GetNavClass(AppView.Overview)" @onclick="@(() => NavigateTo(AppView.Overview))">
            <span>概览</span>
            <small>了解流程并开始使用</small>
        </button>

        <button type="button" class="@GetNavClass(AppView.Intake)" @onclick="@(() => NavigateTo(AppView.Intake))">
            <span>导入与采集</span>
            <small>准备图片、视频和摄像头输入</small>
        </button>

        <button type="button" class="@GetNavClass(AppView.Detect)" @onclick="@(() => NavigateTo(AppView.Detect))">
            <span>执行检测</span>
            <small>选择处理方式并开始识别</small>
        </button>

        <button type="button" class="@GetNavClass(AppView.Results)" @onclick="@(() => NavigateTo(AppView.Results))">
            <span>结果与导出</span>
            <small>查看结果并导出文件</small>
        </button>

    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Navigation.Changed += HandleNavigationChanged;
    }

    private void NavigateTo(AppView view)
    {
        Navigation.NavigateTo(view);
    }

    private string GetNavClass(AppView view)
    {
        return Navigation.CurrentView == view ? "nav-link active" : "nav-link";
    }

    private void HandleNavigationChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Navigation.Changed -= HandleNavigationChanged;
    }
}
