@implements IDisposable
@inject RecognitionWorkbenchState Workbench

<h1>结果与导出</h1>
<p class="page-intro">
    在这里查看当前识别结果，并导出结果图或结构化结果文件。
</p>

<div class="workspace-grid">
    <section class="panel">
        <h2>结果预览</h2>
        <div class="preview-board">
            <div class="preview-tile">
                <span>识别模式</span>
                <strong>@CurrentModeSummary</strong>
            </div>
            <div class="preview-tile">
                <span>检测结果</span>
                <strong>@DetectionSummary</strong>
            </div>
            <div class="preview-tile">
                <span>任务状态</span>
                <strong>@CurrentResultState</strong>
            </div>
        </div>
        <p class="meta">本地识别完成后，结果图或实时识别的最后一帧会直接显示在下方，并可导出结果图或 JSON。</p>
    </section>

    <section class="panel">
        <h2>导出动作</h2>
        <ul class="export-list">
            <li><strong>结果图像</strong><span>导出叠加检测框、类别和置信度的结果图</span></li>
            <li><strong>结构化结果</strong><span>导出 JSON，保存模式、时间和检测框信息</span></li>
            <li><strong>结果视频</strong><span>保留为后续阶段能力，当前仍未启用</span></li>
        </ul>
        <div class="control-row">
            <a class="btn btn-dark @(Workbench.HasDetectionResult ? string.Empty : "disabled")"
               href="@AnnotatedImageDownloadUrl"
               download="recognition-result.png"
               aria-disabled="@(!Workbench.HasDetectionResult)">
                导出结果图像
            </a>
            <a class="btn btn-outline-dark @(CanExportJson ? string.Empty : "disabled")"
               href="@ResultJsonDownloadUrl"
               download="recognition-result.json"
               aria-disabled="@(!CanExportJson)">
                导出 JSON
            </a>
        </div>
    </section>
</div>

@if (Workbench.HasDetectionResult)
{
    <section class="panel panel--wide">
        <div class="panel__row">
            <div>
                <h2>结果图</h2>
                <p class="meta">当前显示的是浏览器端推理后的结果图，视频/摄像头模式下为停止时保存的最后一帧。</p>
            </div>
            @if (Workbench.LastResult is not null)
            {
                <span class="meta">模型版本：@Workbench.LastResult.ModelVersion</span>
            }
        </div>
        <div class="result-preview">
            <img src="@Workbench.AnnotatedImageDataUrl" alt="识别结果图预览" />
        </div>
    </section>
}

@if (Workbench.LastResult is not null)
{
    <section class="panel panel--wide">
        <h2>检测明细</h2>

        @if (Workbench.LastResult.Detections.Count == 0)
        {
            <p class="meta">当前输入未检测到目标。</p>
        }
        else
        {
            <ul class="detection-list">
                @foreach (var detection in Workbench.LastResult.Detections.OrderByDescending(item => item.Confidence))
                {
                    <li>
                        <strong>@detection.Label</strong>
                        <span>置信度 @($"{detection.Confidence:P1}")</span>
                        <span>框：@($"{detection.Box.X:0}, {detection.Box.Y:0}, {detection.Box.Width:0}, {detection.Box.Height:0}")</span>
                    </li>
                }
            </ul>
        }
    </section>
}

@code {
    private string CurrentResultState => Workbench.LastJob is null
        ? "等待开始检测"
        : Workbench.LastJob.Status switch
        {
            RecognitionJobStatuses.Completed => "已完成",
            RecognitionJobStatuses.Queued => "排队中",
            RecognitionJobStatuses.Failed => "失败",
            _ => Workbench.LastJob.Status
        };

    private string CurrentModeSummary => (Workbench.LastResult?.Mode ?? Workbench.EffectiveMode) switch
    {
        RecognitionModes.Local => "本地识别",
        RecognitionModes.Server => "服务器识别",
        _ => "自动选择"
    };
    private string DetectionSummary => Workbench.LastResult is null ? "尚未生成结果" : $"{Workbench.LastResult.Detections.Count} 个目标";
    private bool CanExportJson => Workbench.LastResult is not null;
    private string AnnotatedImageDownloadUrl => Workbench.AnnotatedImageDataUrl ?? "#";
    private string ResultJsonDownloadUrl => Workbench.LastResult is null
        ? "#"
        : $"data:application/json;charset=utf-8,{Uri.EscapeDataString(System.Text.Json.JsonSerializer.Serialize(Workbench.LastResult, new System.Text.Json.JsonSerializerOptions { WriteIndented = true }))}";

    protected override void OnInitialized()
    {
        Workbench.Changed += HandleStateChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Workbench.Changed -= HandleStateChanged;
    }
}

<style>
    .panel--wide {
        margin-top: 1rem;
    }

    .preview-board {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .preview-tile {
        padding: 1rem;
        border-radius: 1rem;
        background: linear-gradient(145deg, #fff8ee, #f1e8d8);
        border: 1px solid rgba(20, 33, 39, 0.08);
        display: grid;
        gap: 0.35rem;
    }

    .preview-tile span {
        color: #687d81;
        font-size: 0.9rem;
    }

    .export-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1rem;
        display: grid;
        gap: 0.75rem;
    }

    .export-list li {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.85rem 0.95rem;
        border-radius: 1rem;
        background: #f4ede0;
    }

    .export-list span {
        color: #5f6f72;
        text-align: right;
    }

    .control-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .result-preview {
        margin-top: 1rem;
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid rgba(20, 33, 39, 0.08);
        background: #fff;
    }

    .result-preview img {
        display: block;
        width: 100%;
        max-height: 540px;
        object-fit: contain;
    }

    .detection-list {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
        display: grid;
        gap: 0.75rem;
    }

    .detection-list li {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 0.9rem 1rem;
        border-radius: 1rem;
        background: #f8f3e9;
    }

    @@media (max-width: 640px) {
        .export-list li,
        .detection-list li {
            flex-direction: column;
        }
    }
</style>
