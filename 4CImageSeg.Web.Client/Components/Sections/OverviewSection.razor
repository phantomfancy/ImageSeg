@inject SpaNavigationState Navigation

<section class="hero">
    <div class="hero__panel">
        <p class="hero__eyebrow">使用流程</p>
        <h1>4C-ai装备识别工具</h1>
        <p class="hero__lead">
            按照“导入与采集、执行检测、结果与导出”的顺序完成识别任务。
            摄像头校准已并入导入与采集，可在准备视频流前先完成配置。
        </p>
        <div class="hero__actions">
            <button type="button" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo(AppView.Intake))">开始导入与采集</button>
            <button type="button" class="btn btn-outline-dark" @onclick="@(() => Navigation.NavigateTo(AppView.Detect))">进入执行检测</button>
        </div>
    </div>

    <div class="hero__aside">
        <div class="metric-card">
            <span>第 1 步</span>
            <strong>准备输入源</strong>
        </div>
        <div class="metric-card">
            <span>第 2 步</span>
            <strong>执行装备检测</strong>
        </div>
        <div class="metric-card">
            <span>第 3 步</span>
            <strong>查看并导出结果</strong>
        </div>
    </div>
</section>

<section class="feature-grid">
    <article class="feature-card">
        <h2>导入与采集</h2>
        <p>支持导入图片、导入视频、接入摄像头视频流，并在同一步骤完成摄像头校准准备。</p>
    </article>
    <article class="feature-card">
        <h2>执行检测</h2>
        <p>根据任务需要选择处理方式，对已准备好的媒体输入发起检测任务。</p>
    </article>
    <article class="feature-card">
        <h2>结果查看</h2>
        <p>集中承接图像、视频和视频流的检测结果，便于核对目标位置、类别和处理状态。</p>
    </article>
    <article class="feature-card">
        <h2>结果导出</h2>
        <p>支持导出结果图像、结果视频和结构化结果，方便归档、复核和后续分析。</p>
    </article>
</section>

<style>
    .hero {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        margin-bottom: 1.5rem;
    }

    .hero__panel,
    .hero__aside {
        border-radius: 1.5rem;
        padding: 1.5rem;
        box-shadow: 0 24px 50px rgba(20, 33, 39, 0.08);
    }

    .hero__panel {
        background: linear-gradient(135deg, #fff9ef 0%, #f4ecda 100%);
    }

    .hero__aside {
        display: grid;
        gap: 0.9rem;
        background: linear-gradient(180deg, #21353c 0%, #172329 100%);
        color: #fff9ef;
    }

    .hero__eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.75rem;
        color: #7f5b1c;
    }

    .hero__lead {
        max-width: 50rem;
        line-height: 1.7;
        color: #344a4f;
    }

    .hero__actions {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-top: 1.2rem;
    }

    .metric-card {
        border-radius: 1rem;
        padding: 1rem 1.1rem;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .metric-card span {
        display: block;
        color: rgba(255, 249, 239, 0.7);
        margin-bottom: 0.25rem;
        font-size: 0.84rem;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
    }

    .feature-card {
        border-radius: 1.3rem;
        padding: 1.2rem;
        background: rgba(255, 252, 247, 0.92);
        border: 1px solid rgba(20, 33, 39, 0.08);
        box-shadow: 0 18px 32px rgba(20, 33, 39, 0.05);
    }

    .feature-card p {
        margin-bottom: 0;
        color: #4c6164;
        line-height: 1.65;
    }
</style>
