@page "/not-found"
@layout MainLayout

<PageTitle>页面未找到</PageTitle>

<section class="empty-state">
    <h1>页面未找到</h1>
    <p>请求的页面不存在，或者已在当前阶段被替换为新的业务路由。</p>
    <a class="btn btn-dark" href="">返回首页</a>
</section>

<style>
    .empty-state {
        padding: 3rem 1.5rem;
        border-radius: 1.5rem;
        background: rgba(255, 252, 247, 0.94);
        border: 1px solid rgba(20, 33, 39, 0.08);
        text-align: center;
    }
</style>
