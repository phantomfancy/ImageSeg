{
  "name": "4cimageseg",
  "private": true,
  "type": "module",
  "workspaces": [
    "imageseg-webapp/contracts",
    "imageseg-webapp/frontend"
  ],
  "dependencies": {
    "vscode-jsonrpc": "^8.2.1"
  },
  "scripts": {
    "start": "aspire run",
    "dev": "aspire run",
    "publish": "aspire publish",
    "deploy": "aspire deploy",
    "static:image": "podman build -f imageseg-webapp/frontend/Dockerfile -t 4cimageseg-static:local .",
    "static:run": "podman run --rm --name 4cimageseg-static -p 8080:80 4cimageseg-static:local",
    "static:stop": "podman rm -f 4cimageseg-static",
    "restore:aspire": "aspire restore",
    "typecheck": "tsgo -p ./imageseg-webapp/tsconfig.root-tools.json --noEmit && node ./scripts/run-workspace.mjs @4cimageseg/frontend typecheck && node ./scripts/run-workspace.mjs @4cimageseg/contracts typecheck",
    "build": "node ./scripts/run-workspace.mjs @4cimageseg/contracts build && node ./scripts/run-workspace.mjs @4cimageseg/frontend build",
    "lint": "node ./scripts/run-workspace.mjs @4cimageseg/frontend lint",
    "test:contracts": "node ./scripts/run-workspace.mjs @4cimageseg/contracts test",
    "test:frontend": "node ./scripts/run-workspace.mjs @4cimageseg/frontend test",
    "verify:training-models": "node --experimental-strip-types ./imageseg-webapp/scripts/verify-training-models.ts",
    "test": "node ./scripts/run-workspace.mjs @4cimageseg/contracts test && node ./scripts/run-workspace.mjs @4cimageseg/frontend test && node --experimental-strip-types ./imageseg-webapp/scripts/verify-training-models.ts"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "tsx": "^4.21.0"
  }
}
