@page "/Error"
@using System.Diagnostics

<PageTitle>错误</PageTitle>

<h1 class="text-danger">发生错误。</h1>
<h2 class="text-danger">请求处理过程中出现异常。</h2>

@if (ShowRequestId)
{
    <p>
        <strong>请求 ID:</strong> <code>@requestId</code>
    </p>
}

<h3>开发模式</h3>
<p>
    切换到 <strong>Development</strong> 环境后，可以看到更详细的错误信息。
</p>
<p>
    <strong>部署环境不应开启 Development。</strong>
    否则可能把敏感异常信息直接暴露给最终用户。
    如需本地调试，请将 <strong>ASPNETCORE_ENVIRONMENT</strong> 设置为 <strong>Development</strong> 后重启应用。
</p>

@code{
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? requestId;
    private bool ShowRequestId => !string.IsNullOrEmpty(requestId);

    protected override void OnInitialized()
    {
        requestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
