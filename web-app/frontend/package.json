{
  "name": "@4cimageseg/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:ort": "node ./scripts/generate-onnx-proto-source.mjs && node ./scripts/copy-ort-assets.mjs",
    "dev": "npm run prepare:ort && vite --configLoader native",
    "build": "npm run prepare:ort && tsgo -b && vite build --configLoader native",
    "typecheck": "tsgo -b --pretty false",
    "lint": "eslint .",
    "test:model-package": "node --experimental-strip-types ./scripts/test-model-package.ts",
    "test": "npm run prepare:ort && npm run lint && npm run typecheck && npm run test:model-package",
    "preview": "vite preview"
  },
  "dependencies": {
    "onnxruntime-web": "^1.24.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
